{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(assets|uploads)/(.*)",
      "dest": "/api/$1/$2"
    },
    {
      "src": "/(?:api/)?(.*).php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    }
  ],
  "build": {
    "env": {
      "FORCE_REDEPLOY": "2026-04-05_V18"
    }
  }
}
