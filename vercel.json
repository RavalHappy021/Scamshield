{
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python"
    },
    "php_app/**/*.php": {
      "runtime": "vercel-php@0.6.1"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*).php", "dest": "/php_app/$1.php" },
    { "src": "/assets/(.*)", "dest": "/php_app/assets/$1" },
    { "src": "/uploads/(.*)", "dest": "/php_app/uploads/$1" },
    { "src": "/(.*)", "dest": "/php_app/$1" }
  ]
}
